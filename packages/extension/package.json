{
	"name": "@happyhackingspace/gitbaz-extension",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "wxt",
		"build": "wxt build",
		"zip": "wxt zip",
		"test": "vitest run --passWithNoTests",
		"test:watch": "vitest",
		"typecheck": "wxt prepare && tsc --noEmit -p .wxt/tsconfig.json",
		"clean": "rm -rf .output .wxt dist"
	},
	"dependencies": {
		"@happyhackingspace/gitbaz": "workspace:*"
	},
	"devDependencies": {
		"@types/chrome": "^0.0.287",
		"wxt": "^0.19.22",
		"vitest": "^3.0.5"
	}
}
